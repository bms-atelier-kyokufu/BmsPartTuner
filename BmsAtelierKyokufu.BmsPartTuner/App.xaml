<Application
    x:Class="BmsAtelierKyokufu.BmsPartTuner.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <!--  Converters  -->
            <converters:ValueToWidthConverter x:Key="ValueToWidthConverter" />

            <ResourceDictionary.MergedDictionaries>
                <!--  Default Theme (Light) - must be loaded first  -->
                <ResourceDictionary Source="/Themes/LightTheme.xaml" />
                <!--  Theme Resources will be dynamically switched in App constructor  -->
                <ResourceDictionary Source="/Themes/DesignTokens.xaml" />
                <ResourceDictionary Source="/Themes/Styles.xaml" />
                <ResourceDictionary Source="/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
