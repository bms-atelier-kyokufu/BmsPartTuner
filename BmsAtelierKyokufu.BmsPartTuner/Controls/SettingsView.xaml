<UserControl
x:Class="BmsAtelierKyokufu.BmsPartTuner.Controls.SettingsView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:converters="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Converters"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:settings="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Controls.Settings"
xmlns:vm="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.ViewModels"
d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
d:DesignHeight="600"
d:DesignWidth="400"
Background="{DynamicResource M3SurfaceBrush}"
mc:Ignorable="d">

<UserControl.Resources>
    <ResourceDictionary>
        <ResourceDictionary.MergedDictionaries>
            <ResourceDictionary Source="/Themes/Styles.xaml" />
        </ResourceDictionary.MergedDictionaries>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanConverter x:Key="InverseBoolConverter" />
    </ResourceDictionary>
</UserControl.Resources>

    <Grid>
        <!--  #region メイン設定画面  -->
        <Grid Visibility="{Binding IsLicenseDetailVisible, Converter={StaticResource InverseBoolConverter}}">
            <Grid.RowDefinitions>
                <!--  ヘッダー  -->
                <RowDefinition Height="Auto" />
                <!--  コンテンツ  -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  ヘッダー  -->
            <Border
                Grid.Row="0"
                Padding="20,16"
                BorderBrush="{DynamicResource M3OutlineBrush}"
                BorderThickness="0,0,0,1">
                <Grid>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource M3OnSurfaceBrush}"
                        Text="設定" />
                    <Button
                        HorizontalAlignment="Right"
                        Command="{Binding CloseCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Content="✕"
                        FontSize="16"
                        Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                        Style="{StaticResource M3IconButton}" />
                </Grid>
            </Border>

            <!--  タブコンテンツ  -->
            <TabControl
                Grid.Row="1"
                Background="Transparent"
                BorderThickness="0"
                SelectedIndex="{Binding SelectedTabIndex}">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border
                                        x:Name="TabBorder"
                                        Padding="16,12"
                                        Background="Transparent"
                                        Cursor="Hand">
                                        <TextBlock
                                            x:Name="TabText"
                                            FontSize="14"
                                            FontWeight="Medium"
                                            Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                            Text="{TemplateBinding Header}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabText" Property="Foreground" Value="{DynamicResource M3PrimaryBrush}" />
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource M3PrimaryBrush}" />
                                            <Setter TargetName="TabBorder" Property="BorderThickness" Value="0,0,0,2" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource M3SurfaceVariantBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!--  全般タブ  -->
                <TabItem Header="全般">
                    <settings:GeneralTab />
                </TabItem>

                <!--  情報タブ  -->
                <TabItem Header="情報">
                    <settings:AboutTab />
                </TabItem>

                <!--  サポートタブ  -->
                <TabItem Header="サポート">
                    <ScrollViewer Padding="20" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border
                                Margin="0,0,0,16"
                                Padding="16"
                                Background="{DynamicResource M3SurfaceVariantBrush}"
                                CornerRadius="16">
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource M3OnSurfaceBrush}"
                                        Text="不具合報告・機能要望" />
                                    <TextBlock
                                        Margin="0,0,0,16"
                                        FontSize="12"
                                        Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                        Text="バグの報告や新機能のリクエストは、GitHub Issues からお願いします。"
                                        TextWrapping="Wrap" />
                                    <Button
                                        Padding="16,8"
                                        HorizontalAlignment="Left"
                                        Command="{Binding OpenGitHubIssuesCommand}"
                                        Content="🐛 GitHub Issues を開く"
                                        Cursor="Hand"
                                        FontSize="13"
                                        Style="{StaticResource M3PrimaryButton}" />
                                </StackPanel>
                            </Border>

                            <Border
                                Padding="16"
                                Background="{DynamicResource M3SurfaceVariantBrush}"
                                CornerRadius="16">
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,12"
                                        FontSize="14"
                                        FontWeight="SemiBold"
                                        Foreground="{DynamicResource M3OnSurfaceBrush}"
                                        Text="開発者に連絡" />
                                    <TextBlock
                                        Margin="0,0,0,16"
                                        FontSize="12"
                                        Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                        Text="その他のお問い合わせは X (Twitter) からどうぞ。"
                                        TextWrapping="Wrap" />
                                    <Button
                                        Padding="16,8"
                                        HorizontalAlignment="Left"
                                        Command="{Binding OpenTwitterCommand}"
                                        Content="𝕏 @rian_eimu を開く"
                                        Cursor="Hand"
                                        FontSize="13"
                                        Style="{StaticResource M3PrimaryButton}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
        <!--  #endregion  -->

        <!--  #region ライセンス詳細画面  -->
        <settings:LicenseDetailView Visibility="{Binding IsLicenseDetailVisible, Converter={StaticResource BoolToVis}}" />
        <!--  #endregion  -->
    </Grid>
</UserControl>
