<UserControl
    x:Class="BmsAtelierKyokufu.BmsPartTuner.Controls.SideSheet"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="400"
    mc:Ignorable="d">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!--  Scrim (背景オーバーレイ) のスタイル  -->
        <Style x:Key="ScrimStyle" TargetType="Border">
            <Setter Property="Background" Value="#80000000" />
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsOpen, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <!--  Scrim (背景オーバーレイ)  -->
        <Border
            x:Name="Scrim"
            Panel.ZIndex="100"
            Background="#80000000"
            MouseLeftButtonDown="Scrim_MouseLeftButtonDown"
            Opacity="0"
            Visibility="Collapsed" />

        <!--  サイドシート本体  -->
        <Border
            x:Name="SheetContainer"
            HorizontalAlignment="Right"
            Panel.ZIndex="101"
            Background="{DynamicResource M3SurfaceBrush}"
            BorderBrush="{DynamicResource M3OutlineBrush}"
            BorderThickness="1,0,0,0"
            Effect="{DynamicResource M3Elevation2}"
            RenderTransformOrigin="1,0.5">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SheetTranslate" X="400" />
            </Border.RenderTransform>
            <ContentPresenter Content="{Binding Content, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </Border>
    </Grid>
</UserControl>
