<UserControl
x:Class="BmsAtelierKyokufu.BmsPartTuner.Controls.Settings.AboutTab"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:local="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Controls"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
d:DesignHeight="400"
d:DesignWidth="350"
mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="SettingsSection" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource M3SurfaceVariantBrush}" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource M3PrimaryBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock
                            x:Name="LinkText"
                            Foreground="{TemplateBinding Foreground}"
                            Text="{TemplateBinding Content}"
                            TextDecorations="Underline" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="LinkText" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer
        Padding="20"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!--  アプリ情報セクション  -->
            <Border Style="{StaticResource SettingsSection}">
                <StackPanel HorizontalAlignment="Center">
                    <!--  SVGロゴ（テーマ対応）  -->
                    <svgc:SvgViewbox
                        x:Name="LogoViewbox"
                        Width="200"
                        Height="80"
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center" />
                    <TextBlock
                        Margin="0,0,0,4"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        FontWeight="Bold"
                        Foreground="{DynamicResource M3OnSurfaceBrush}"
                        Text="{Binding AppName}" />
                    <TextBlock
                        Margin="0,0,0,12"
                        HorizontalAlignment="Center"
                        FontSize="14"
                        Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                        Text="{Binding AppVersion}" />

                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                            Text="by " />
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{DynamicResource M3OnSurfaceBrush}"
                            Text="{Binding AuthorInfo}" />
                    </StackPanel>

                    <Button
                        Margin="0,12,0,0"
                        HorizontalAlignment="Center"
                        Command="{Binding OpenGitHubCommand}"
                        Content="{Binding GitHubUrl}"
                        FontSize="12"
                        Style="{StaticResource LinkButton}" />
                </StackPanel>
            </Border>

            <!--  ライセンスセクション  -->
            <Border Style="{StaticResource SettingsSection}">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource M3OnSurfaceBrush}"
                        Text="オープンソースライセンス" />

                    <!--  ライセンスリスト  -->
                    <ItemsControl ItemsSource="{Binding Licenses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource M3OutlineBrush}" BorderThickness="0,0,0,1">
                                    <Button
                                        Command="{Binding DataContext.OpenLicenseDetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border
                                                                x:Name="Bd"
                                                                Padding="12,8"
                                                                Background="{TemplateBinding Background}">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource M3SurfaceContainerHighestBrush}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <Grid Margin="0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                Foreground="{DynamicResource M3OnSurfaceBrush}"
                                                Text="{Binding Name}"
                                                TextTrimming="CharacterEllipsis">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsAppLicense}" Value="True">
                                                                <Setter Property="FontWeight" Value="Bold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock
                                                Grid.Column="1"
                                                VerticalAlignment="Center"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="16"
                                                Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                                Text="&#xE76C;" />
                                            <!--  ChevronRight  -->
                                        </Grid>
                                    </Button>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
