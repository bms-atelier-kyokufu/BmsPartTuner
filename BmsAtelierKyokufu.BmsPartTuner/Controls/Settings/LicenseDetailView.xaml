<UserControl
    x:Class="BmsAtelierKyokufu.BmsPartTuner.Controls.Settings.LicenseDetailView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:markdig="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="400"
    d:DesignWidth="350"
    Background="{DynamicResource M3SurfaceBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!--  ヘッダー  -->
        <Border
            Grid.Row="0"
            Padding="12,16"
            BorderBrush="{DynamicResource M3OutlineBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Command="{Binding CloseLicenseDetailCommand}"
                    Content="&#xE72B;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="16"
                    Foreground="{DynamicResource M3OnSurfaceBrush}"
                    Style="{StaticResource M3IconButton}"
                    ToolTip="戻る"/>

                <TextBlock
                    Grid.Column="1"
                    Margin="12,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource M3OnSurfaceBrush}"
                    Text="{Binding SelectedLicense.Name}"
                    TextTrimming="CharacterEllipsis"/>
            </Grid>
        </Border>

        <!--  ライセンス本文  -->
        <ScrollViewer
            x:Name="LicenseScrollViewer"
            Grid.Row="1"
            Padding="16"
            CanContentScroll="True"
            PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
            <Border
                Padding="12"
                Background="{DynamicResource M3SurfaceVariantBrush}"
                CornerRadius="8"
                TextElement.FontFamily="Consolas, Monospace"
                TextElement.FontSize="12"
                TextElement.Foreground="{DynamicResource M3OnSurfaceBrush}">
                <markdig:MarkdownViewer
                    x:Name="LicenseMarkdownViewer"
                    Foreground="{DynamicResource M3OnSurfaceBrush}"
                    Markdown="{Binding SelectedLicense.Content, Mode=OneWay}"
                    PreviewMouseWheel="Content_PreviewMouseWheel">
                    <!--  MarkdownViewer の共通スタイルは Themes/Styles.xaml で定義  -->
                </markdig:MarkdownViewer>
            </Border>
        </ScrollViewer>

        <Grid.InputBindings>
            <KeyBinding Key="Esc"
                    Command="{Binding CloseLicenseDetailCommand}"/>
            <KeyBinding Key="Backspace"
                    Command="{Binding CloseLicenseDetailCommand}"/>
        </Grid.InputBindings>
    </Grid>
</UserControl>
