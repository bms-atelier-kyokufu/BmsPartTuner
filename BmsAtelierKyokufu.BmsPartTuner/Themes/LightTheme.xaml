<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Material Design 3 - Light Theme Color Palette
        Why: 明度が高く、視認性に優れたライト配色を採用します。
        
        このファイルはテーマ切り替え時にリアルタイムで差し替えられます。
        ColorとBrushの両方を定義することで、DynamicResourceが正しく動作します。
    -->

    <!--  Primary Roles  -->
    <Color x:Key="M3PrimaryColor">#6750A4</Color>
    <Color x:Key="M3OnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="M3PrimaryContainerColor">#EADDFF</Color>
    <Color x:Key="M3OnPrimaryContainerColor">#21005D</Color>

    <!--  Secondary Roles  -->
    <Color x:Key="M3SecondaryColor">#625B71</Color>
    <Color x:Key="M3OnSecondaryColor">#FFFFFF</Color>

    <!--  Surface Roles  -->
    <Color x:Key="M3SurfaceColor">#FFFBFE</Color>
    <Color x:Key="M3OnSurfaceColor">#1C1B1F</Color>
    <Color x:Key="M3SurfaceVariantColor">#E7E0EC</Color>
    <Color x:Key="M3OnSurfaceVariantColor">#49454F</Color>

    <!--  Outline & Extras  -->
    <Color x:Key="M3OutlineColor">#79747E</Color>
    <Color x:Key="M3InverseSurfaceColor">#313033</Color>
    <Color x:Key="M3InverseOnSurfaceColor">#F4EFF4</Color>

    <!--  Extended Colors  -->
    <Color x:Key="M3BackgroundColor">#FAFAFA</Color>
    <Color x:Key="M3PrimaryHoverColor">#7E5DB0</Color>
    <Color x:Key="M3PrimaryPressedColor">#5A3D8A</Color>
    <Color x:Key="M3ChipBackgroundColor">#E8DEF8</Color>
    <Color x:Key="M3ChipHoverColor">#D0BCFE</Color>
    <Color x:Key="M3PlaceholderBackgroundColor">#F3EDF7</Color>

    <!--  Warning Colors  -->
    <Color x:Key="M3WarningColor">#FF9800</Color>
    <Color x:Key="M3WarningContainerColor">#FFE0B2</Color>
    <Color x:Key="M3WarningContainerLightColor">#FFF3E0</Color>

    <!--  Error Colors  -->
    <Color x:Key="M3ErrorColor">#B3261E</Color>
    <Color x:Key="M3OnErrorColor">#FFFFFF</Color>
    <Color x:Key="M3ErrorContainerColor">#F2B8B5</Color>
    <Color x:Key="M3OnErrorContainerColor">#410E0B</Color>

    <!--  Drag Speed Indicator Colors  -->
    <Color x:Key="M3DragSpeedFastColor">#4CAF50</Color>
    <Color x:Key="M3DragSpeedFineColor">#FFB300</Color>

    <!--  Tertiary Colors  -->
    <Color x:Key="M3TertiaryColor">#7D5260</Color>
    <Color x:Key="M3OnTertiaryColor">#FFFFFF</Color>
    <Color x:Key="M3TertiaryContainerColor">#FFD8E4</Color>
    <Color x:Key="M3OnTertiaryContainerColor">#31111D</Color>

    <Color x:Key="M3SurfaceContainerHighestColor">#E6E1E5</Color>

    <!--  ========== Brush Definitions ==========  -->
    <!--  Primary Brushes  -->
    <SolidColorBrush x:Key="M3PrimaryBrush" Color="#6750A4" />
    <SolidColorBrush x:Key="M3OnPrimaryBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="M3PrimaryContainerBrush" Color="#EADDFF" />
    <SolidColorBrush x:Key="M3OnPrimaryContainerBrush" Color="#21005D" />

    <!--  Surface Brushes  -->
    <SolidColorBrush x:Key="M3SurfaceBrush" Color="#FFFBFE" />
    <SolidColorBrush x:Key="M3OnSurfaceBrush" Color="#1C1B1F" />
    <SolidColorBrush x:Key="M3SurfaceVariantBrush" Color="#E7E0EC" />
    <SolidColorBrush x:Key="M3OnSurfaceVariantBrush" Color="#49454F" />
    <SolidColorBrush x:Key="M3SurfaceContainerHighestBrush" Color="#E6E1E5" />

    <!--  Outline Brushes  -->
    <SolidColorBrush x:Key="M3OutlineBrush" Color="#79747E" />

    <!--  Extended Brushes  -->
    <SolidColorBrush x:Key="M3BackgroundBrush" Color="#FAFAFA" />
    <SolidColorBrush x:Key="M3PrimaryHoverBrush" Color="#7E5DB0" />
    <SolidColorBrush x:Key="M3PrimaryPressedBrush" Color="#5A3D8A" />
    <SolidColorBrush x:Key="M3ChipBackgroundBrush" Color="#E8DEF8" />
    <SolidColorBrush x:Key="M3ChipHoverBrush" Color="#D0BCFE" />
    <SolidColorBrush x:Key="M3PlaceholderBackgroundBrush" Color="#F3EDF7" />

    <!--  Warning Brushes  -->
    <SolidColorBrush x:Key="M3WarningBrush" Color="#FF9800" />
    <SolidColorBrush x:Key="M3WarningContainerBrush" Color="#FFE0B2" />
    <SolidColorBrush x:Key="M3WarningContainerLightBrush" Color="#FFF3E0" />

    <!--  Error Brushes  -->
    <SolidColorBrush x:Key="M3ErrorBrush" Color="#B3261E" />
    <SolidColorBrush x:Key="M3OnErrorBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="M3ErrorContainerBrush" Color="#F2B8B5" />
    <SolidColorBrush x:Key="M3OnErrorContainerBrush" Color="#410E0B" />

    <!--  Tertiary Brushes  -->
    <SolidColorBrush x:Key="M3TertiaryBrush" Color="#7D5260" />
    <SolidColorBrush x:Key="M3TertiaryContainerBrush" Color="#FFD8E4" />
    <SolidColorBrush x:Key="M3OnTertiaryContainerBrush" Color="#31111D" />

    <!--  Inverse Brushes  -->
    <SolidColorBrush x:Key="M3InverseSurfaceBrush" Color="#313033" />
    <SolidColorBrush x:Key="M3InverseOnSurfaceBrush" Color="#F4EFF4" />

    <!--  Drag Speed Brushes  -->
    <SolidColorBrush x:Key="M3DragSpeedFastBrush" Color="#4CAF50" />
    <SolidColorBrush x:Key="M3DragSpeedFineBrush" Color="#FFB300" />
</ResourceDictionary>
