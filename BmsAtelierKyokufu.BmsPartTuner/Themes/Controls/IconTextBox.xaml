<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Converters"
    xmlns:ui="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Infrastructure.UI">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="TextBox.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--  Converters  -->
    <converters:ObjectToBoolConverter x:Key="ObjectToBoolConverter" />

    <!--
        M3 Outlined TextBox with Icon Support
        Leading/Trailing Iconを柔軟に配置できる汎用スタイル

        使用例:
        <TextBox Style="{StaticResource Material.Styles.TextBox.WithIcons}"
                 ui:TextBoxHelper.LeadingIcon="{StaticResource MyIcon}"
                 ui:TextBoxHelper.TrailingIcon="{StaticResource MyButton}" />
    -->
    <Style
        x:Key="Material.Styles.TextBox.WithIcons"
        BasedOn="{StaticResource Material.Styles.TextBox.Outlined}"
        TargetType="TextBox">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Main Input Container  -->
                        <Border
                            x:Name="PART_MainBorder"
                            Grid.Row="0"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding Path=(ui:TextBoxHelper.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Leading Icon  -->
                                <ContentPresenter
                                    x:Name="PART_LeadingIcon"
                                    Grid.Column="0"
                                    Margin="12,0,4,0"
                                    VerticalAlignment="Center"
                                    Content="{Binding Path=(ui:TextBoxHelper.LeadingIcon), RelativeSource={RelativeSource TemplatedParent}}"
                                    Visibility="Collapsed" />

                                <!--  Text Input Area  -->
                                <Grid Grid.Column="1" VerticalAlignment="Center">
                                    <ScrollViewer
                                        x:Name="PART_ContentHost"
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"
                                        Focusable="False"
                                        HorizontalScrollBarVisibility="Hidden"
                                        VerticalScrollBarVisibility="Hidden" />

                                    <TextBlock
                                        x:Name="PART_Placeholder"
                                        Margin="{TemplateBinding Padding}"
                                        VerticalAlignment="Center"
                                        Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                        IsHitTestVisible="False"
                                        Text="{Binding Path=(ui:TextBoxHelper.Placeholder), RelativeSource={RelativeSource TemplatedParent}}"
                                        Visibility="Collapsed" />
                                </Grid>

                                <!--  Trailing Icon  -->
                                <Grid Grid.Column="2">
                                    <!--  Custom Trailing Icon (通常時)  -->
                                    <ContentPresenter
                                        x:Name="PART_TrailingIcon"
                                        Margin="4,0,8,0"
                                        VerticalAlignment="Center"
                                        Content="{Binding Path=(ui:TextBoxHelper.TrailingIcon), RelativeSource={RelativeSource TemplatedParent}}"
                                        Visibility="Collapsed" />

                                    <!--  Error Icon (エラー時)  -->
                                    <TextBlock
                                        x:Name="PART_ErrorIcon"
                                        Margin="0,0,12,0"
                                        VerticalAlignment="Center"
                                        FontSize="18"
                                        Foreground="{DynamicResource M3ErrorBrush}"
                                        Text="❗"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Grid>
                        </Border>

                        <!--  Supporting Text  -->
                        <TextBlock
                            x:Name="PART_SupportingText"
                            Grid.Row="1"
                            Margin="16,4,16,0"
                            FontSize="12"
                            Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                            Text="{Binding Path=(ui:TextBoxHelper.SupportingText), RelativeSource={RelativeSource TemplatedParent}}"
                            TextWrapping="Wrap"
                            Visibility="Collapsed" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  Show Leading Icon if set  -->
                        <DataTrigger Binding="{Binding Path=(ui:TextBoxHelper.LeadingIcon), RelativeSource={RelativeSource Self}, Converter={StaticResource ObjectToBoolConverter}}" Value="True">
                            <Setter TargetName="PART_LeadingIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_ContentHost" Property="Margin" Value="8,14,16,14" />
                        </DataTrigger>

                        <!--  Show Trailing Icon if set  -->
                        <DataTrigger Binding="{Binding Path=(ui:TextBoxHelper.TrailingIcon), RelativeSource={RelativeSource Self}, Converter={StaticResource ObjectToBoolConverter}}" Value="True">
                            <Setter TargetName="PART_TrailingIcon" Property="Visibility" Value="Visible" />
                        </DataTrigger>

                        <!--  Show Supporting Text if set  -->
                        <DataTrigger Binding="{Binding Path=(ui:TextBoxHelper.SupportingText), RelativeSource={RelativeSource Self}, Converter={StaticResource ObjectToBoolConverter}}" Value="True">
                            <Setter TargetName="PART_SupportingText" Property="Visibility" Value="Visible" />
                        </DataTrigger>

                        <!--  Placeholder visibility  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsFocused" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_Placeholder" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!--  Hover State  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_MainBorder" Property="BorderBrush" Value="{DynamicResource M3OnSurfaceBrush}" />
                        </Trigger>

                        <!--  Focus State  -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="PART_MainBorder" Property="BorderBrush" Value="{DynamicResource M3PrimaryBrush}" />
                            <Setter TargetName="PART_MainBorder" Property="BorderThickness" Value="2" />
                        </Trigger>

                        <!--  Error State  -->
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="PART_MainBorder" Property="BorderBrush" Value="{DynamicResource M3ErrorBrush}" />
                            <Setter TargetName="PART_MainBorder" Property="BorderThickness" Value="2" />
                            <Setter TargetName="PART_SupportingText" Property="Foreground" Value="{DynamicResource M3ErrorBrush}" />
                            <Setter TargetName="PART_SupportingText" Property="Text" Value="{Binding Path=(Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="PART_SupportingText" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_TrailingIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_ErrorIcon" Property="Visibility" Value="Visible" />
                            <Setter Property="CaretBrush" Value="{DynamicResource M3ErrorBrush}" />
                        </Trigger>

                        <!--  Disabled State  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
