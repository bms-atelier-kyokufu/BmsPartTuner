<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Converters"
    xmlns:ui="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Infrastructure.UI">

    <!--  Converters  -->
    <converters:ObjectToBoolConverter x:Key="ObjectToBoolConverter" />

    <!--
        M3 Outlined TextBox Base Style
        Material Design 3 準拠の Outlined Text Field スタイル
        エラーメッセージとSupporting Text完全対応
    -->
    <Style x:Key="Material.Styles.TextBox.Outlined" TargetType="TextBox">
        <Setter Property="Foreground" Value="{DynamicResource M3OnSurfaceBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource M3OutlineBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontFamily" Value="Segoe UI" />
        <Setter Property="Height" Value="56" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CaretBrush" Value="{DynamicResource M3PrimaryBrush}" />
        <Setter Property="SelectionBrush" Value="{DynamicResource M3PrimaryBrush}" />
        <Setter Property="SelectionOpacity" Value="0.3" />
        <Setter Property="ui:TextBoxHelper.CornerRadius" Value="4" />
        <Setter Property="Validation.ErrorTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <!--  エラーテンプレートは空（Supporting Textで表示）  -->
                    <AdornedElementPlaceholder x:Name="adorner" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Main Input Container  -->
                        <Border
                            x:Name="PART_Border"
                            Grid.Row="0"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding Path=(ui:TextBoxHelper.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Text Content  -->
                                <ScrollViewer
                                    x:Name="PART_ContentHost"
                                    Grid.Column="0"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Focusable="False"
                                    HorizontalScrollBarVisibility="Hidden"
                                    VerticalScrollBarVisibility="Hidden" />

                                <!--  Placeholder  -->
                                <TextBlock
                                    x:Name="PART_Placeholder"
                                    Grid.Column="0"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                    IsHitTestVisible="False"
                                    Text="{Binding Path=(ui:TextBoxHelper.Placeholder), RelativeSource={RelativeSource TemplatedParent}}"
                                    Visibility="Collapsed" />

                                <!--  Trailing Icon Area  -->
                                <ContentPresenter
                                    x:Name="PART_TrailingIcon"
                                    Grid.Column="1"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Content="{Binding Path=(ui:TextBoxHelper.TrailingIcon), RelativeSource={RelativeSource TemplatedParent}}"
                                    Visibility="Collapsed" />

                                <!--  Error Icon (❗)  -->
                                <TextBlock
                                    x:Name="PART_ErrorIcon"
                                    Grid.Column="1"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{DynamicResource M3ErrorBrush}"
                                    Text="❗"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Border>

                        <!--  Supporting Text / Error Messages  -->
                        <Grid Grid.Row="1" Margin="16,4,16,0">
                            <!--  Supporting Text (通常時)  -->
                            <TextBlock
                                x:Name="PART_SupportingText"
                                FontSize="12"
                                Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                Text="{Binding Path=(ui:TextBoxHelper.SupportingText), RelativeSource={RelativeSource TemplatedParent}}"
                                TextWrapping="Wrap"
                                Visibility="Collapsed" />

                            <!--  Error Message (エラー時)  -->
                            <ItemsControl
                                x:Name="PART_ErrorMessages"
                                ItemsSource="{Binding Path=(Validation.Errors), RelativeSource={RelativeSource TemplatedParent}}"
                                Visibility="Collapsed">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            FontSize="12"
                                            Foreground="{DynamicResource M3ErrorBrush}"
                                            Text="{Binding ErrorContent}"
                                            TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  Show Trailing Icon if set  -->
                        <DataTrigger Binding="{Binding Path=(ui:TextBoxHelper.TrailingIcon), RelativeSource={RelativeSource Self}, Converter={StaticResource ObjectToBoolConverter}}" Value="True">
                            <Setter TargetName="PART_TrailingIcon" Property="Visibility" Value="Visible" />
                        </DataTrigger>

                        <!--  Show Supporting Text if set and no errors  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ui:TextBoxHelper.SupportingText" Value="" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_SupportingText" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>
                        <Trigger Property="ui:TextBoxHelper.SupportingText" Value="{x:Null}">
                            <Setter TargetName="PART_SupportingText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Validation.HasError" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_SupportingText" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!--  Placeholder visibility  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsFocused" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_Placeholder" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!--  Hover State  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource M3OnSurfaceBrush}" />
                        </Trigger>

                        <!--  Focus State  -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource M3PrimaryBrush}" />
                            <Setter TargetName="PART_Border" Property="BorderThickness" Value="2" />
                        </Trigger>

                        <!--  Error State  -->
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource M3ErrorBrush}" />
                            <Setter TargetName="PART_Border" Property="BorderThickness" Value="2" />
                            <Setter TargetName="PART_ErrorIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_TrailingIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_ErrorMessages" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_SupportingText" Property="Visibility" Value="Collapsed" />
                            <Setter Property="CaretBrush" Value="{DynamicResource M3ErrorBrush}" />
                        </Trigger>

                        <!--  Disabled State  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Legacy aliases for backward compatibility  -->
    <Style
        x:Key="TextBox"
        BasedOn="{StaticResource Material.Styles.TextBox.Outlined}"
        TargetType="TextBox" />
    <Style
        x:Key="M3TextBoxBase"
        BasedOn="{StaticResource Material.Styles.TextBox.Outlined}"
        TargetType="TextBox" />

</ResourceDictionary>
