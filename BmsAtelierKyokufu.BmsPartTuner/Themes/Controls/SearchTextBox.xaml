<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Converters"
    xmlns:ui="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Infrastructure.UI">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="TextBox.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--  Converters  -->
    <converters:ObjectToBoolConverter x:Key="ObjectToBoolConverter" />

    <!--
        M3 SearchTextBox Style with Floating Label and Icon Integration
        Floating Label + Leading Icon(検索) + Trailing Icon(クリア)を統合
    -->
    <Style
        x:Key="Material.Styles.TextBox.Search"
        BasedOn="{StaticResource Material.Styles.TextBox.Outlined}"
        TargetType="TextBox">
        <Setter Property="ui:TextBoxHelper.IsLabelPinned" Value="True" />
        <Setter Property="ui:TextBoxHelper.EnableClearButton" Value="True" />
        <Setter Property="Height" Value="Auto" />
        <Setter Property="MinHeight" Value="56" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid ClipToBounds="False">
                        <!--  Main Search TextBox Container  -->
                        <Grid MinHeight="56" Margin="0,8,0,0">
                            <!--  Border  -->
                            <Border
                                x:Name="PART_MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{Binding Path=(ui:TextBoxHelper.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}"
                                SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  Leading Icon: Search  -->
                                    <ContentPresenter
                                        x:Name="PART_LeadingIcon"
                                        Grid.Column="0"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"
                                        Content="{Binding Path=(ui:TextBoxHelper.LeadingIcon), RelativeSource={RelativeSource TemplatedParent}}" />

                                    <!--  Text Input Area  -->
                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                        <ScrollViewer
                                            x:Name="PART_ContentHost"
                                            VerticalAlignment="Center"
                                            Focusable="False"
                                            HorizontalScrollBarVisibility="Hidden"
                                            VerticalScrollBarVisibility="Hidden" />

                                        <TextBlock
                                            x:Name="PlaceholderText"
                                            VerticalAlignment="Center"
                                            Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                            IsHitTestVisible="False"
                                            Text="{Binding Path=(ui:TextBoxHelper.Placeholder), RelativeSource={RelativeSource TemplatedParent}}"
                                            Visibility="Collapsed" />
                                    </Grid>

                                    <!--  Trailing Icon: Clear Button  -->
                                    <Button
                                        x:Name="PART_ClearButton"
                                        Grid.Column="2"
                                        Width="32"
                                        Height="32"
                                        Margin="4,0,8,0"
                                        Content="✕"
                                        FontSize="12"
                                        Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                        Style="{DynamicResource M3IconButton}"
                                        Visibility="Collapsed" />
                                </Grid>
                            </Border>
                        </Grid>

                        <!--  Floating Label Container: ボーダーの上端に配置  -->
                        <Border
                            x:Name="PART_FloatingLabelContainer"
                            Padding="4,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="{DynamicResource M3BackgroundBrush}"
                            IsHitTestVisible="False"
                            RenderTransformOrigin="0,0"
                            Visibility="Collapsed">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="LabelScale" ScaleX="1" ScaleY="1" />
                                    <TranslateTransform x:Name="LabelTranslate" X="12" Y="0" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <TextBlock
                                x:Name="PART_FloatingLabel"
                                FontSize="12"
                                Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                Text="{Binding Path=(ui:TextBoxHelper.Label), RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  Show Floating Label when has text or is focused  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsFocused" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PART_FloatingLabelContainer" Property="Visibility" Value="Collapsed" />
                        </MultiTrigger>

                        <!--  Show Floating Label if Label is set and (has text OR is focused)  -->
                        <DataTrigger Binding="{Binding Path=(ui:TextBoxHelper.Label), RelativeSource={RelativeSource Self}, Converter={StaticResource ObjectToBoolConverter}}" Value="True">
                            <Setter TargetName="PART_FloatingLabelContainer" Property="Visibility" Value="Visible" />
                        </DataTrigger>

                        <!--  Show default search icon if no custom icon provided  -->
                        <Trigger Property="ui:TextBoxHelper.LeadingIcon" Value="{x:Null}">
                            <Setter TargetName="PART_LeadingIcon" Property="Content">
                                <Setter.Value>
                                    <TextBlock
                                        FontSize="18"
                                        Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                        Text="🔍" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>

                        <!--  Placeholder visibility  -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Text" Value="" />
                                <Condition Property="IsFocused" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <!--  Show clear button when keyboard focus is within (includes child elements like clear button) and has text  -->
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="PART_ClearButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="PART_ClearButton" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  Hover State  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_MainBorder" Property="BorderBrush" Value="{DynamicResource M3OnSurfaceBrush}" />
                        </Trigger>

                        <!--  Focus State  -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="PART_MainBorder" Property="BorderBrush" Value="{DynamicResource M3PrimaryBrush}" />
                            <Setter TargetName="PART_MainBorder" Property="BorderThickness" Value="2" />
                            <Setter TargetName="PART_FloatingLabel" Property="Foreground" Value="{DynamicResource M3PrimaryBrush}" />
                        </Trigger>

                        <!--  Disabled State  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Legacy aliases  -->
    <Style
        x:Key="SearchTextBox"
        BasedOn="{StaticResource Material.Styles.TextBox.Search}"
        TargetType="TextBox" />
    <Style
        x:Key="M3SearchTextBox"
        BasedOn="{StaticResource Material.Styles.TextBox.Search}"
        TargetType="TextBox" />

</ResourceDictionary>
