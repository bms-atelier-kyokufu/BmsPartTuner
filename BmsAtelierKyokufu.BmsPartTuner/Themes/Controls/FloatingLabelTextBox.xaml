<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Infrastructure.UI">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="TextBox.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        M3 Outlined TextBox with Floating Label Support
        FloatingLabelBehaviorと協調して動作：初期位置Y=18（中央）、Floating時Y=8（上部）
        非フォーカス時はラベルがプレースホルダーを兼ね、フォーカス時のみWatermark表示
        
        【枠消え問題対策】
        BorderThicknessを動的に変更するとレイアウトが不安定になり枠が消えることがある。
        代わりに、通常Border(1px)とフォーカスBorder(2px)を重ねて表示/非表示で切り替える。
    -->
    <Style
        x:Key="Material.Styles.TextBox.OutlinedWithLabel"
        BasedOn="{StaticResource Material.Styles.TextBox.Outlined}"
        TargetType="TextBox">
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid Margin="0,8,0,0" ClipToBounds="False">
                        <!--  Normal Border Layer (1px) - 常に表示  -->
                        <Border
                            x:Name="PART_Border"
                            Margin="0,8,0,0"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{Binding Path=(ui:TextBoxHelper.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Text Content  -->
                                <ScrollViewer
                                    x:Name="PART_ContentHost"
                                    Grid.Column="0"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Focusable="False"
                                    HorizontalScrollBarVisibility="Hidden"
                                    VerticalScrollBarVisibility="Hidden" />

                                <!--  Adornment Area  -->
                                <ContentPresenter
                                    Grid.Column="1"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    ContentSource="Tag" />
                            </Grid>
                        </Border>

                        <!--  Focus/Error Overlay Border (2px) - フォーカス/エラー時のみ表示  -->
                        <Border
                            x:Name="PART_FocusBorder"
                            Margin="0,8,0,0"
                            BorderBrush="{DynamicResource M3PrimaryBrush}"
                            BorderThickness="2"
                            CornerRadius="{Binding Path=(ui:TextBoxHelper.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}"
                            IsHitTestVisible="False"
                            SnapsToDevicePixels="True"
                            Visibility="Collapsed" />

                        <!--  Floating Label Container: 初期位置は中央(Y=22), Behaviorで制御  -->
                        <Border
                            x:Name="PART_FloatingLabelContainer"
                            Padding="4,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Background="{TemplateBinding Background}"
                            IsHitTestVisible="False"
                            RenderTransformOrigin="0,0">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="LabelScale" ScaleX="1.0" ScaleY="1.0" />
                                    <TranslateTransform x:Name="LabelTranslate" X="18" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <TextBlock
                                x:Name="PART_FloatingLabel"
                                FontSize="14"
                                Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                Text="{Binding Path=(ui:TextBoxHelper.Label), RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>

                        <!--  Watermark (Placeholder) Host: フォーカス時のみ表示, Behaviorで制御  -->
                        <TextBlock
                            x:Name="PART_WatermarkHost"
                            Margin="14,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="14"
                            Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                            IsHitTestVisible="False"
                            Opacity="0"
                            Text="{Binding Path=(ui:TextBoxHelper.Placeholder), RelativeSource={RelativeSource TemplatedParent}}" />
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  Hide label if not set  -->
                        <Trigger Property="ui:TextBoxHelper.Label" Value="">
                            <Setter TargetName="PART_FloatingLabelContainer" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ui:TextBoxHelper.Label" Value="{x:Null}">
                            <Setter TargetName="PART_FloatingLabelContainer" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  Hover State  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource M3OnSurfaceBrush}" />
                        </Trigger>

                        <!--  Focus State - オーバーレイBorderを表示  -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="PART_FocusBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_FocusBorder" Property="BorderBrush" Value="{DynamicResource M3PrimaryBrush}" />
                            <Setter TargetName="PART_FloatingLabel" Property="Foreground" Value="{DynamicResource M3PrimaryBrush}" />
                        </Trigger>

                        <!--  Error State - オーバーレイBorderをエラー色で表示  -->
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="PART_FocusBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_FocusBorder" Property="BorderBrush" Value="{DynamicResource M3ErrorBrush}" />
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource M3ErrorBrush}" />
                            <Setter TargetName="PART_FloatingLabel" Property="Foreground" Value="{DynamicResource M3ErrorBrush}" />
                            <Setter Property="CaretBrush" Value="{DynamicResource M3ErrorBrush}" />
                        </Trigger>

                        <!--  Disabled State  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
