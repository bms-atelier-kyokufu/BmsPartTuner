<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:behaviors="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Infrastructure.Behaviors"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:ui="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Infrastructure.UI">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="TextBox.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        M3 Numeric TextBox Style
        数値入力専用のOutlined Text Field（中央揃え表示）
        コンパクトなサイズ対応
    -->
    <Style
        x:Key="Material.Styles.TextBox.Numeric"
        BasedOn="{StaticResource Material.Styles.TextBox.Outlined}"
        TargetType="TextBox">
        <Setter Property="Height" Value="Auto" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="4,6" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{DynamicResource M3OnSurfaceBrush}" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid ClipToBounds="False">
                        <!--  Main Input Container  -->
                        <Border
                            x:Name="PART_Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{Binding Path=(ui:TextBoxHelper.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}"
                            SnapsToDevicePixels="True">
                            <ScrollViewer
                                x:Name="PART_ContentHost"
                                Margin="{TemplateBinding Padding}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                Focusable="False"
                                HorizontalScrollBarVisibility="Hidden"
                                VerticalScrollBarVisibility="Hidden" />
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  Hover State  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource M3OnSurfaceBrush}" />
                        </Trigger>

                        <!--  Focus State  -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource M3PrimaryBrush}" />
                            <Setter TargetName="PART_Border" Property="BorderThickness" Value="2" />
                        </Trigger>

                        <!--  Error State  -->
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource M3ErrorBrush}" />
                            <Setter TargetName="PART_Border" Property="BorderThickness" Value="2" />
                            <Setter Property="CaretBrush" Value="{DynamicResource M3ErrorBrush}" />
                        </Trigger>

                        <!--  Disabled State  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Legacy aliases  -->
    <Style
        x:Key="NumericTextBox"
        BasedOn="{StaticResource Material.Styles.TextBox.Numeric}"
        TargetType="TextBox" />

</ResourceDictionary>

