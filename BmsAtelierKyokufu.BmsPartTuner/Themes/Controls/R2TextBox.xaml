<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="clr-namespace:BmsAtelierKyokufu.BmsPartTuner.Infrastructure.UI">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="FloatingLabelTextBox.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--  Converters  -->
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <!--
        M3 R2 (Correlation Coefficient) TextBox Style
        相関係数入力専用 + Floating Label 固定表示（縁に常駐） + AI最適化ボタン統合
        Width: 160px固定（仕様要件）
        
        【枠消え問題対策】
        BorderThicknessを動的に変更するとレイアウトが不安定になり枠が消えることがある。
        代わりに、通常Border(1px)とフォーカスBorder(2px)を重ねて表示/非表示で切り替える。
        CornerRadiusは他のテキストボックスと統一して4を使用。
    -->
    <Style
        x:Key="Material.Styles.TextBox.R2"
        BasedOn="{StaticResource Material.Styles.TextBox.OutlinedWithLabel}"
        TargetType="TextBox">
        <Setter Property="Width" Value="160" />
        <Setter Property="ui:TextBoxHelper.IsLabelPinned" Value="True" />
        <Setter Property="ui:TextBoxHelper.CornerRadius" Value="4" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="8,0,36,0" />
        <Setter Property="Foreground" Value="{DynamicResource M3OnSurfaceBrush}" />
        <Setter Property="Background" Value="{DynamicResource M3SurfaceBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource M3OutlineBrush}" />

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid ClipToBounds="False">
                        <!--  Normal Border Layer (1px) - 常に表示  -->
                        <Border
                            x:Name="PART_Border"
                            Margin="0,8,0,0"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!--  Text Input Area  -->
                                <ScrollViewer
                                    x:Name="PART_ContentHost"
                                    Grid.Column="0"
                                    Margin="{TemplateBinding Padding}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    Focusable="False"
                                    HorizontalScrollBarVisibility="Hidden"
                                    VerticalScrollBarVisibility="Hidden" />

                                <!--  AI Optimization Button (Trailing Adornment)  -->
                                <Button
                                    x:Name="PART_AiButton"
                                    Grid.Column="1"
                                    Width="32"
                                    Height="32"
                                    Margin="0,0,4,0"
                                    Command="{Binding Path=(ui:TextBoxHelper.AiOptimizationCommand), RelativeSource={RelativeSource TemplatedParent}}"
                                    FontSize="16"
                                    ToolTip="AI最適化"
                                    Visibility="{Binding Path=(ui:TextBoxHelper.HasAiOptimization), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Cursor" Value="Hand" />
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid>
                                                            <Border
                                                                x:Name="Border"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="100">
                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    FontSize="16"
                                                                    Foreground="{DynamicResource M3PrimaryBrush}"
                                                                    Text="✨" />
                                                            </Border>

                                                            <Border
                                                                x:Name="StateLayer"
                                                                Background="{DynamicResource M3PrimaryBrush}"
                                                                CornerRadius="100"
                                                                IsHitTestVisible="False"
                                                                Opacity="0" />
                                                        </Grid>

                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Trigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetName="StateLayer"
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                To="0.08"
                                                                                Duration="0:0:0.1">
                                                                                <DoubleAnimation.EasingFunction>
                                                                                    <CubicEase EasingMode="EaseOut" />
                                                                                </DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.EnterActions>
                                                                <Trigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation
                                                                                Storyboard.TargetName="StateLayer"
                                                                                Storyboard.TargetProperty="Opacity"
                                                                                To="0"
                                                                                Duration="0:0:0.1" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </Trigger.ExitActions>
                                                            </Trigger>

                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter TargetName="StateLayer" Property="Opacity" Value="0.12" />
                                                            </Trigger>

                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.38" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>

                        <!--  Focus/Error Overlay Border (2px) - フォーカス/エラー時のみ表示  -->
                        <Border
                            x:Name="PART_FocusBorder"
                            Margin="0,8,0,0"
                            BorderBrush="{DynamicResource M3PrimaryBrush}"
                            BorderThickness="2"
                            CornerRadius="4"
                            IsHitTestVisible="False"
                            SnapsToDevicePixels="True"
                            Visibility="Collapsed" />

                        <!--  Floating Label Container: 常に縁に固定（Y=0, Scale=0.75）  -->
                        <Border
                            x:Name="PART_FloatingLabelContainer"
                            Padding="4,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Background="{DynamicResource M3BackgroundBrush}"
                            IsHitTestVisible="False"
                            RenderTransformOrigin="0,0">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="0.75" ScaleY="0.75" />
                                    <TranslateTransform X="10" Y="0" />
                                </TransformGroup>
                            </Border.RenderTransform>
                            <TextBlock
                                x:Name="PART_FloatingLabel"
                                FontSize="14"
                                Foreground="{DynamicResource M3OnSurfaceVariantBrush}"
                                Text="{Binding Path=(ui:TextBoxHelper.Label), RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!--  Hide label if not set  -->
                        <Trigger Property="ui:TextBoxHelper.Label" Value="">
                            <Setter TargetName="PART_FloatingLabelContainer" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ui:TextBoxHelper.Label" Value="{x:Null}">
                            <Setter TargetName="PART_FloatingLabelContainer" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!--  Hover State  -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource M3OnSurfaceBrush}" />
                        </Trigger>

                        <!--  Focus State - オーバーレイBorderを表示  -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="PART_FocusBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_FocusBorder" Property="BorderBrush" Value="{DynamicResource M3PrimaryBrush}" />
                            <Setter TargetName="PART_FloatingLabel" Property="Foreground" Value="{DynamicResource M3PrimaryBrush}" />
                        </Trigger>

                        <!--  Error State - オーバーレイBorderをエラー色で表示  -->
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter TargetName="PART_FocusBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="PART_FocusBorder" Property="BorderBrush" Value="{DynamicResource M3ErrorBrush}" />
                            <Setter TargetName="PART_Border" Property="BorderBrush" Value="{DynamicResource M3ErrorBrush}" />
                            <Setter TargetName="PART_FloatingLabel" Property="Foreground" Value="{DynamicResource M3ErrorBrush}" />
                        </Trigger>

                        <!--  Disabled State  -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.38" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!--  Alias  -->
    <Style
        x:Key="R2TextBox"
        BasedOn="{StaticResource Material.Styles.TextBox.R2}"
        TargetType="TextBox" />

</ResourceDictionary>
