<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Material Design 3 - Dark Theme Color Palette
        Why: 目への負担を軽減しつつ、コントラスト比を適切に維持したダーク配色を採用します。
        
        このファイルはテーマ切り替え時にリアルタイムで差し替えられます。
        ColorとBrushの両方を定義することで、DynamicResourceが正しく動作します。
    -->

    <!--  Primary Roles  -->
    <Color x:Key="M3PrimaryColor">#D0BCFE</Color>
    <Color x:Key="M3OnPrimaryColor">#381E72</Color>
    <Color x:Key="M3PrimaryContainerColor">#4F378B</Color>
    <Color x:Key="M3OnPrimaryContainerColor">#EADDFF</Color>

    <!--  Secondary Roles  -->
    <Color x:Key="M3SecondaryColor">#CCC2DC</Color>
    <Color x:Key="M3OnSecondaryColor">#332D41</Color>

    <!--  Surface Roles  -->
    <Color x:Key="M3SurfaceColor">#1C1B1F</Color>
    <Color x:Key="M3OnSurfaceColor">#E6E1E5</Color>
    <Color x:Key="M3SurfaceVariantColor">#49454F</Color>
    <Color x:Key="M3OnSurfaceVariantColor">#CAC4D0</Color>

    <!--  Outline & Extras  -->
    <Color x:Key="M3OutlineColor">#938F99</Color>
    <Color x:Key="M3InverseSurfaceColor">#E6E1E5</Color>
    <Color x:Key="M3InverseOnSurfaceColor">#313033</Color>
    <Color x:Key="M3ErrorColor">#F2B8B5</Color>
    <Color x:Key="M3OnErrorColor">#601410</Color>

    <!--  Extended Colors  -->
    <Color x:Key="M3BackgroundColor">#1C1B1F</Color>
    <Color x:Key="M3PrimaryHoverColor">#E1D3FF</Color>
    <Color x:Key="M3PrimaryPressedColor">#B9A1F5</Color>
    <Color x:Key="M3ChipBackgroundColor">#4F378B</Color>
    <Color x:Key="M3ChipHoverColor">#6750A4</Color>
    <Color x:Key="M3PlaceholderBackgroundColor">#2B2930</Color>
    
    <!--  Warning Colors  -->
    <Color x:Key="M3WarningContainerColor">#3E2A00</Color>
    <Color x:Key="M3WarningColor">#FFB951</Color>
    <Color x:Key="M3WarningContainerLightColor">#5A3F00</Color>
    
    <!--  Drag Speed Indicator Colors  -->
    <Color x:Key="M3DragSpeedFastColor">#FFB951</Color>
    <Color x:Key="M3DragSpeedFineColor">#64B5F6</Color>

    <!--  Tertiary Colors  -->
    <Color x:Key="M3TertiaryColor">#EFB8C8</Color>
    <Color x:Key="M3OnTertiaryColor">#492532</Color>
    <Color x:Key="M3TertiaryContainerColor">#633B48</Color>
    <Color x:Key="M3OnTertiaryContainerColor">#FFD8E4</Color>

    <Color x:Key="M3SurfaceContainerHighestColor">#36343B</Color>

    <!--  Error Colors  -->
    <Color x:Key="M3ErrorContainerColor">#8C1D18</Color>
    <Color x:Key="M3OnErrorContainerColor">#F2B8B5</Color>

    <!--  ========== Brush Definitions ========== -->
    <!--  Primary Brushes  -->
    <SolidColorBrush x:Key="M3PrimaryBrush" Color="#D0BCFE" />
    <SolidColorBrush x:Key="M3OnPrimaryBrush" Color="#381E72" />
    <SolidColorBrush x:Key="M3PrimaryContainerBrush" Color="#4F378B" />
    <SolidColorBrush x:Key="M3OnPrimaryContainerBrush" Color="#EADDFF" />

    <!--  Surface Brushes  -->
    <SolidColorBrush x:Key="M3SurfaceBrush" Color="#1C1B1F" />
    <SolidColorBrush x:Key="M3OnSurfaceBrush" Color="#E6E1E5" />
    <SolidColorBrush x:Key="M3SurfaceVariantBrush" Color="#49454F" />
    <SolidColorBrush x:Key="M3OnSurfaceVariantBrush" Color="#CAC4D0" />
    <SolidColorBrush x:Key="M3SurfaceContainerHighestBrush" Color="#36343B" />

    <!--  Outline Brushes  -->
    <SolidColorBrush x:Key="M3OutlineBrush" Color="#938F99" />

    <!--  Extended Brushes  -->
    <SolidColorBrush x:Key="M3BackgroundBrush" Color="#1C1B1F" />
    <SolidColorBrush x:Key="M3PrimaryHoverBrush" Color="#E1D3FF" />
    <SolidColorBrush x:Key="M3PrimaryPressedBrush" Color="#B9A1F5" />
    <SolidColorBrush x:Key="M3ChipBackgroundBrush" Color="#4F378B" />
    <SolidColorBrush x:Key="M3ChipHoverBrush" Color="#6750A4" />
    <SolidColorBrush x:Key="M3PlaceholderBackgroundBrush" Color="#2B2930" />

    <!--  Warning Brushes  -->
    <SolidColorBrush x:Key="M3WarningBrush" Color="#FFB951" />
    <SolidColorBrush x:Key="M3WarningContainerBrush" Color="#3E2A00" />
    <SolidColorBrush x:Key="M3WarningContainerLightBrush" Color="#5A3F00" />

    <!--  Error Brushes  -->
    <SolidColorBrush x:Key="M3ErrorBrush" Color="#F2B8B5" />
    <SolidColorBrush x:Key="M3OnErrorBrush" Color="#601410" />
    <SolidColorBrush x:Key="M3ErrorContainerBrush" Color="#8C1D18" />
    <SolidColorBrush x:Key="M3OnErrorContainerBrush" Color="#F2B8B5" />

    <!--  Tertiary Brushes  -->
    <SolidColorBrush x:Key="M3TertiaryBrush" Color="#EFB8C8" />
    <SolidColorBrush x:Key="M3TertiaryContainerBrush" Color="#633B48" />
    <SolidColorBrush x:Key="M3OnTertiaryContainerBrush" Color="#FFD8E4" />

    <!--  Inverse Brushes  -->
    <SolidColorBrush x:Key="M3InverseSurfaceBrush" Color="#E6E1E5" />
    <SolidColorBrush x:Key="M3InverseOnSurfaceBrush" Color="#313033" />

    <!--  Drag Speed Brushes  -->
    <SolidColorBrush x:Key="M3DragSpeedFastBrush" Color="#FFB951" />
    <SolidColorBrush x:Key="M3DragSpeedFineBrush" Color="#64B5F6" />
</ResourceDictionary>
